{
  "manifest_version": 3,
  "name": "Forum Collector",
  "version": "1.5.6",
  "description": "Thu thập pick XSMB từ forumketqua.net (mở bát, thảo luận, chăn nuôi)",
  "permissions": ["alarms", "storage", "downloads", "cookies", "scripting", "tabs"],
  "host_permissions": [
    "https://forumketqua.net/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://127.0.0.1:18715/*",
    "http://localhost:18715/*",
    "http://127.0.0.1:8081/*",
    "http://localhost:8081/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Forum Collector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://forumketqua.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
